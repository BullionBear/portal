# Copy to /opt/portal/deploy/.env on the server (not overwritten by CI).
# Discord Developer Portal → OAuth2 → Redirects, add:
#   https://portal.lynkora.com/api/public/auth/discord/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
